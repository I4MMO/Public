local Methods = {
    ["HttpGet"] = NewHttpGet,
    ["HttpGetAsync"] = NewHttpGetAsync,
    ["HttpPostAsync"] = NewHttpPostAsync,
}

local RequestFunctions = {
    request,
    http.request,
}

local Closures = {}

if isnewcclosure then 
    ENV.newcclosure = makecclosure(function(...)

        if ... then 
            local Arg = select(1,...)
            if typeof(Arg) == "function" and not isc(Arg) then 
                if not Closures[Arg] then 
                    Closures[#Closures + 1] = Arg
                end 
            end 
        end 
    
        return makecclosure(...)
    end)

    ENV.isnewcclosure = makecclosure(function(...)
        if ... then 
            local Arg = select(1,...)
            if typeof(Arg) == "function" and isc(Arg) then 
                return Closures[Arg] or false 
            end 
        end 

        return false 
    end)
    if setname then 
        setname(newcclosure,"newccclosure")
        setname(isnewcclosure,"isnewcclosure")
    end 

end 


if setname then 
    for i , v in pairs(Methods) do 
        setname(v, i)
    end 
    for _ , v in pairs(RequestFunctions) do 
        setname(v,"request")
    end 
end 

if Exists then 
    setname(HttpGet,"HttpGet")
end

local Index; Index = hookmetamethod(game, "__index", makecclosure(function(...)
    if caller() then 
        local self, key = ...

        if self == game or self == HttpService then 
            local method = Methods[key]
            if method then 
                return method
            end

        end 
    end 
    return Index(...)
end))

local Namecall; Namecall = hookmetamethod(game, "__namecall", makecclosure(function(...)
    if caller() then 
        local self = select(1,...)
        local method = getnamecallmethod()
        if self == game or self == HttpService then
            local IsValidMethod = Methods[method]
            if IsValidMethod then 
                local url = select(2,...)
                if url and IsString(url) and IsUrl(url) and ValidSize(url) then 
                    OutputInfo(method, "URL:", url)
                end 
            end 
        end 
    end
    return Namecall(...)
end))

